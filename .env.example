# Google Cloud - enable: Maps JavaScript API, Places API, Geocoding API, Solar API, Maps Static API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# Server-side key (can be same as above but with no HTTP referrer restriction; restrict by IP instead)
GOOGLE_SOLAR_API_KEY=

# Stripe (leave blank for mock checkout)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_STRIPE_PRICE_STARTER=
NEXT_PUBLIC_STRIPE_PRICE_PRO=
NEXT_PUBLIC_STRIPE_PRICE_VOLUME=

# Public site URL used for Stripe return URLs
NEXT_PUBLIC_SITE_URL=http://localhost:3000
