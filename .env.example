# =============================================================================
# Roof Today — environment variables
# =============================================================================
# Without keys, the app runs in MOCK + CALIBRATION mode:
#   - /api/geocode hashes addresses to pseudo-coords (CONUS), but the three
#     known EagleView calibration addresses always resolve to their pinned coords.
#   - /api/measure synthesizes a roof report; for calibration addresses it emits
#     truth-table values so `npm run calibrate` passes deterministically.
#   - /api/checkout returns a fake success URL.
# Configure the keys below for real behavior.

# ---- Google Cloud -----------------------------------------------------------
# Enable on the project: Maps JavaScript API, Places API, Geocoding API,
# Solar API (paid), Maps Static API.
# Browser key (HTTP referrer-restricted) — used by the Places autocomplete.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# Server-side key for Solar API + server-side geocoding fallback.
# Same project as above; restrict by IP, not referrer.
GOOGLE_SOLAR_API_KEY=
# Optional: separate server-side geocoding key. Falls back to NEXT_PUBLIC_GOOGLE_MAPS_API_KEY.
GOOGLE_GEOCODING_API_KEY=

# ---- Stripe -----------------------------------------------------------------
# Leave blank for mock checkout (writes a /success?session=mock_... URL).
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Webhook secret from `stripe listen --forward-to .../api/stripe-webhook` (dev)
# or the dashboard "Signing secret" (prod). Required to credit reports on
# checkout.session.completed; without it, /api/stripe-webhook returns 503.
STRIPE_WEBHOOK_SECRET=
# Optional pre-created price IDs. If absent, checkout uses inline price_data
# from TIER_PRICING in lib/stripe.ts.
NEXT_PUBLIC_STRIPE_PRICE_STARTER=
NEXT_PUBLIC_STRIPE_PRICE_PRO=
NEXT_PUBLIC_STRIPE_PRICE_VOLUME=

# ---- Credit cookie ----------------------------------------------------------
# HMAC secret for the signed `rt_credits` cookie. When set, /api/measure
# enforces credits (402 with code=no_credits when balance is zero) and the
# Stripe webhook tops up the balance on completed checkouts. When BLANK the
# system runs in legacy "mock measure for everyone" mode — appropriate for
# local dev and the calibration harness, never for production.
# Generate one: `openssl rand -base64 48`
SESSION_SIGNING_SECRET=

# ---- Site -------------------------------------------------------------------
# Used by Stripe return URLs and by absolute links in API responses.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- Calibration harness ----------------------------------------------------
# Override the target the regression suite runs against (default: localhost:3000).
# CALIBRATE_BASE_URL=https://staging.roof-today.com
