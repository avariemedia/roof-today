# Site URL (used for canonical/OG/sitemap)
NEXT_PUBLIC_SITE_URL=https://roof-today.com

# Stripe (server)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe (client)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Stripe Price IDs (one per tier)
NEXT_PUBLIC_STRIPE_PRICE_STARTER=price_...   # 2 reports / $25
NEXT_PUBLIC_STRIPE_PRICE_PRO=price_...       # 10 reports / $50
NEXT_PUBLIC_STRIPE_PRICE_VOLUME=price_...    # 50 reports / $200

# Google Maps + Places (client-side autocomplete, satellite map)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIza...

# Google Solar API (server-side roof measurement)
# Can be the same key as NEXT_PUBLIC_GOOGLE_MAPS_API_KEY if the key is not
# restricted by HTTP referer, or a separate server-only key with Solar API enabled.
GOOGLE_SOLAR_API_KEY=AIza...

# Analytics (optional)
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_META_PIXEL_ID=
